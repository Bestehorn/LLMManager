#!/usr/bin/env bash
# .githooks/pre-commit — VERSION-CONTROLLED, shared pre-commit hook.
#
# This file lives in the repo's tracked `.githooks/` directory (NOT in the
# untracked `.git/hooks/`), so the standard it enforces travels with the
# project to every clone and developer. Git runs it because the repo sets
# `core.hooksPath=.githooks` in local config (done once per clone by
# `scripts/setup-hooks.sh`; see CLAUDE.md / .claude/rules and the setup
# prompt's Part 2.3).
#
# PROJECT-SPECIFIC TOOLCHAIN: bestehorn-llmmanager uses ruff (format + check)
# at LINE LENGTH 100 (NOT 120) — this is a documented hard constraint
# (.claude/rules/tech-stack.md, CLAUDE.md). This hook therefore runs the fast
# ruff checks: ruff-check (with autofix) then ruff-format. Slow checks (mypy,
# pytest) are left for CI and manual `pre-commit run <id>` / the /run-ci slash
# command.
#
# src/bestehorn_llmmanager/_version.py is auto-generated by setuptools-scm and
# is excluded from every hook (the exclude lives in .pre-commit-config.yaml).
#
# Portable by design: it does NOT hardcode an absolute venv path. It locates
# the project's venv at runtime from the main checkout, so the same committed
# file works on every machine, OS, and inside git worktrees (where the venv
# lives in the MAIN checkout, not the worktree).
set -euo pipefail

# Resolve the MAIN working tree (the parent of the common git dir). From a
# normal checkout this is the repo root; from a worktree it is the main repo
# root — which is where the venv lives.
GIT_COMMON_DIR="$(git rev-parse --git-common-dir)"
case "$GIT_COMMON_DIR" in
    /*|[A-Za-z]:*) ;;                                  # already absolute
    *) GIT_COMMON_DIR="$(git rev-parse --show-toplevel)/$GIT_COMMON_DIR" ;;
esac
MAIN_CHECKOUT="$(cd "$(dirname "$GIT_COMMON_DIR")" && pwd)"

# Locate the venv pre-commit executable (Windows vs *nix layout).
if [ -x "$MAIN_CHECKOUT/venv/Scripts/pre-commit.exe" ]; then
    PRECOMMIT="$MAIN_CHECKOUT/venv/Scripts/pre-commit.exe"
elif [ -x "$MAIN_CHECKOUT/venv/bin/pre-commit" ]; then
    PRECOMMIT="$MAIN_CHECKOUT/venv/bin/pre-commit"
else
    echo "ERROR: pre-commit not found in the project venv under $MAIN_CHECKOUT/venv" >&2
    echo "Create/refresh the venv:  python -m venv venv && pip install -e '.[dev]'" >&2
    exit 1
fi

# Run the fast hooks defined in .pre-commit-config.yaml, against the staged
# files for this commit: ruff-check (lint, with --fix) then ruff-format. Slow
# hooks (mypy, pytest) are skipped here and run in CI.
"$PRECOMMIT" run ruff-check  --config "$MAIN_CHECKOUT/.pre-commit-config.yaml" || exit $?
exec "$PRECOMMIT" run ruff-format --config "$MAIN_CHECKOUT/.pre-commit-config.yaml"
